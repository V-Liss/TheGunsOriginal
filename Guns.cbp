<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="Guns" />
		<Option pch_mode="2" />
		<Option compiler="gcc" />
		<Build>
			<Target title="Debug">
				<Option output="bin/Debug/Guns" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Debug/" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-g" />
					<Add option="-DSFML_STATIC" />
				</Compiler>
				<Linker>
					<Add library="winmm" />
					<Add library="sfml-system" />
					<Add library="sfml-window" />
					<Add library="sfml-graphics" />
					<Add library="sfml-audio" />
					<Add library="sfml-network" />
				</Linker>
			</Target>
			<Target title="Release">
				<Option output="bin/Release/Guns" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Release/" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-O2" />
					<Add option="-DSFML_STATIC" />
				</Compiler>
				<Linker>
					<Add option="-s" />
					<Add library="winmm" />
					<Add library="sfml-system" />
					<Add library="sfml-window" />
					<Add library="sfml-graphics" />
					<Add library="sfml-audio" />
					<Add library="sfml-network" />
				</Linker>
			</Target>
		</Build>
		<Compiler>
			<Add option="-Wall" />
			<Add option="-fexceptions" />
			<Add option="-DSFML_STATIC" />
			<Add directory="./libs/include" />
		</Compiler>
		<Linker>
			<Add option="-static-libstdc++" />
			<Add option="-static-libgcc" />
			<Add option="-static" />
			<Add directory="./libs/lib" />
		</Linker>
		<Unit filename="main.cpp" />
		<Extensions>
			<lib_finder disable_auto="1" />
		</Extensions>
	</Project>
</CodeBlocks_project_file>
